# =============================================================================
# Ask JG Gemini Demo Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# MODEL SELECTION
# =============================================================================
# "ga" (default) = Vertex AI with GA model (production stable)
# "preview" = Google AI API with preview model (has thinking mode)
GEMINI_MODEL=ga

# =============================================================================
# VERTEX AI CREDENTIALS (Required for GA model - default)
# =============================================================================
# Service account credentials as JSON string or path to file
GOOGLE_VERTEX_CREDENTIALS={"type": "service_account", ...}
# GOOGLE_VERTEX_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# GOOGLE AI API (Required for preview model only)
# =============================================================================
# Uncomment if using GEMINI_MODEL=preview
# Get your API key from: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-ai-api-key
# THINKING_BUDGET_TOKENS=0  # 0=disabled, 512-1024 for complex reasoning

# =============================================================================
# BOT CONFIGURATION
# =============================================================================
# Name the bot uses when introducing itself
BOT_NAME=Maya

# Health/readiness probe port (default: 8080)
PORT=8080

# System prompt source: "local" (default) or "gcs"
# - local: Load from bot/prompts/demo_system_prompt.md
# - gcs: Load from GCS bucket (requires GCS_BUCKET_NAME), falls back to local
PROMPT_SOURCE=local

# =============================================================================
# CALL SAFEGUARDS
# =============================================================================
# Maximum call duration in seconds (default: 840 = 14 minutes)
# Set slightly below Gemini Live's 15-minute limit to allow graceful goodbye
MAX_CALL_DURATION_SECS=840

# User idle timeout in seconds (default: 120 = 2 minutes)
# Time of user silence before prompting/ending call
USER_IDLE_TIMEOUT_SECS=120

# Connection timeout in seconds (default: 60)
# Kill bot if no client connects within this time
CONNECTION_TIMEOUT_SECS=60

# =============================================================================
# CALL RECORDING (Optional)
# =============================================================================
# Recording mode: disabled, mono, stereo, both
RECORDING_MODE=disabled

# GCS bucket for storing recordings (required if recording enabled)
# Uses the same GOOGLE_VERTEX_CREDENTIALS from above
GCS_BUCKET_NAME=

# =============================================================================
# END-OF-CALL REPORTING (Optional)
# =============================================================================
# Webhook URL to send end-of-call reports to
WEBHOOK_URL=

# API key for webhook authentication
WEBHOOK_API_KEY=

# Authentication type: "header" (default) or "body"
# - header: API key sent in X-API-Key HTTP header (standard webhooks)
# - body: API key wrapped in JSON envelope (for Google Apps Script)
WEBHOOK_AUTH_TYPE=header

# Enable LLM-generated call summary in end-of-call reports (default: true)
# Uses Gemini 2.5 Flash to generate a brief summary of the call transcript
# Requires Vertex AI credentials (uses same credentials as main model)
ENABLE_SUMMARY=true

# Enable transcript post-processing for translation and STT correction (default: true)
# Translates non-English messages and fixes speech-to-text errors
# Requires Vertex AI credentials (uses same credentials as main model)
ENABLE_TRANSCRIPT_POST_PROCESSING=true
