# =============================================================================
# Custom Voice Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# MODEL SELECTION
# =============================================================================
# "ga" (default) = Vertex AI with GA model (production stable)
# "preview"      = Google AI API with preview model (has thinking mode)
GEMINI_MODEL=ga

# =============================================================================
# VERTEX AI CREDENTIALS (Required for GA model — default)
# =============================================================================
# Service account credentials as JSON string or path to file
GOOGLE_VERTEX_CREDENTIALS={"type": "service_account", ...}
# GOOGLE_VERTEX_CREDENTIALS_PATH=/path/to/credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# GOOGLE AI API (Required for preview model only)
# =============================================================================
# Uncomment if using GEMINI_MODEL=preview
# Get your API key from: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-ai-api-key

# =============================================================================
# LIVEKIT (Required)
# =============================================================================
# LiveKit server WebSocket URL (e.g. wss://your-server.livekit.cloud)
LIVEKIT_URL=wss://your-server.livekit.cloud

# LiveKit credentials for token generation
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Room the agent joins (default: voice-agent)
LIVEKIT_ROOM=voice-agent

# Optionally supply a pre-generated participant token to skip server-side
# token generation (useful in environments without livekit-api installed)
# LIVEKIT_TOKEN=

# BOT CONFIGURATION
# =============================================================================
# Name the bot uses when introducing itself
BOT_NAME=Maya

# =============================================================================
# CALL SAFEGUARDS
# =============================================================================
# Maximum call duration in seconds (default: 840 = 14 minutes)
MAX_CALL_DURATION_SECS=840

# User idle timeout in seconds (default: 120 = 2 minutes)
USER_IDLE_TIMEOUT_SECS=120

# =============================================================================
# VAD TUNING (optional — sensible defaults shown)
# =============================================================================
VAD_CONFIDENCE=0.75
VAD_START_SECS=0.2
VAD_STOP_SECS=0.2
VAD_MIN_VOLUME=0.6
